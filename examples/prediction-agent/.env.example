# Starknet RPC
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io
STARKNET_RPC_FALLBACK_URLS=https://starknet-sepolia.public.blastapi.io,https://rpc.starknet-testnet.lava.build
STARKNET_RPC_FAILOVER_ENABLED=true
STARKNET_CHAIN_ID=SN_SEPOLIA
# tamagotchi | auto | core | oracle | scout
NEXT_PUBLIC_SWARM_LOGO_VARIANT=tamagotchi

# Agent Account (for autonomous betting)
AGENT_PRIVATE_KEY=0x...
AGENT_ADDRESS=0x...

# Deployed Contract Addresses (Sepolia)
MARKET_FACTORY_ADDRESS=0x...
ACCURACY_TRACKER_ADDRESS=0x...
COLLATERAL_TOKEN_ADDRESS=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d

# LLM provider routing
# Base provider (auto picks xAI, then Anthropic, then local Ollama)
AGENT_LLM_PROVIDER=auto
# Per-task provider routes: default | anthropic | xai | local
AGENT_LLM_PROVIDER_FORECAST=default
AGENT_LLM_PROVIDER_DEBATE=default
AGENT_LLM_PROVIDER_RESOLUTION=default
AGENT_LLM_PROVIDER_TRIAGE=default
AGENT_LLM_MODEL=
AGENT_LLM_FORECAST_MODEL=
AGENT_LLM_DEBATE_MODEL=
AGENT_LLM_RESOLUTION_MODEL=
AGENT_LLM_TRIAGE_MODEL=
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_ENABLE_NATIVE_TOOLS=true
XAI_ENABLE_WEB_SEARCH=true
XAI_ENABLE_X_SEARCH=true
XAI_ENABLE_CODE_EXECUTION=true
XAI_ENABLE_COLLECTIONS_SEARCH=true
XAI_COLLECTION_IDS=
XAI_CODE_TOOL_TYPE=code_execution
# Local model backend (Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_FORECAST_MODEL=
OLLAMA_DEBATE_MODEL=
OLLAMA_RESOLUTION_MODEL=
OLLAMA_TRIAGE_MODEL=
OLLAMA_API_KEY=
AGENT_TOOL_MAX_TURNS=8
AGENT_LOOP_TICK_TIMEOUT_MS=35000
AGENT_RESEARCH_STEP_TIMEOUT_MS=15000
AGENT_RESEARCH_TOTAL_TIMEOUT_MS=30000
AGENT_RESEARCH_TRIAGE_ENABLED=true
AGENT_AUTO_RESOLVE_ENABLED=true
AGENT_AUTO_RESOLVE_EVERY=1
AGENT_AUTO_RESOLVE_MAX_PER_TICK=1
AGENT_AUTO_RESOLVE_COOLDOWN_SECS=900
AGENT_ACTORS_PER_TICK=3
AGENT_SINGLE_AGENT_MODE=false
AGENT_MIN_EVIDENCE_SOURCES=2
AGENT_MIN_EVIDENCE_POINTS=4
AGENT_CONSENSUS_ENABLED=true
AGENT_CONSENSUS_MAX_PEERS=8
AGENT_CONSENSUS_BRIER_FLOOR=0.05
AGENT_CONSENSUS_LEAD_WEIGHT=1.0
AGENT_CONSENSUS_MIN_PEERS=1
AGENT_CONSENSUS_MIN_PEER_PREDICTIONS=3
AGENT_CONSENSUS_MIN_TOTAL_PEER_WEIGHT=2
AGENT_CONSENSUS_MAX_SHIFT_PCT=15
AGENT_CONSENSUS_AUTOTUNE_ENABLED=true
AGENT_CONSENSUS_AUTOTUNE_WINDOW=24
AGENT_CONSENSUS_AUTOTUNE_MIN_SAMPLES=6
AGENT_CONSENSUS_AUTOTUNE_DRIFT_LOW=0.01
AGENT_CONSENSUS_AUTOTUNE_DRIFT_HIGH=0.08
AGENT_CONSENSUS_AUTOTUNE_MAX_SHIFT_FLOOR_PCT=5
AGENT_CONSENSUS_AUTOTUNE_MIN_PEERS_CAP=4
AGENT_CONSENSUS_AUTOTUNE_MIN_PEER_PREDICTIONS_CAP=8
AGENT_CONSENSUS_AUTOTUNE_MIN_TOTAL_PEER_WEIGHT_CAP=12

# Optional: metrics alerting hooks (webhook / Slack / PagerDuty)
AGENT_ALERTING_ENABLED=false
AGENT_ALERT_WEBHOOK_URL=
AGENT_ALERT_SLACK_WEBHOOK_URL=
AGENT_ALERT_PAGERDUTY_ROUTING_KEY=
AGENT_ALERT_WEBHOOK_MIN_SEVERITY=info
AGENT_ALERT_SLACK_MIN_SEVERITY=warning
AGENT_ALERT_PAGERDUTY_MIN_SEVERITY=critical
AGENT_ALERT_TEST_SECRET=
AGENT_ALERT_COOLDOWN_SECS=600
AGENT_ALERT_ACTION_WINDOW=200
AGENT_ALERT_MIN_CONSENSUS_SAMPLES=10
AGENT_ALERT_ERROR_RATE_THRESHOLD=0.25
AGENT_ALERT_CONSENSUS_BLOCK_RATE_THRESHOLD=0.35
AGENT_ALERT_CONSENSUS_CLAMP_RATE_THRESHOLD=0.4
AGENT_ALERT_FAILOVER_EVENTS_THRESHOLD=3
AGENT_ALERT_HEARTBEAT_ERRORS_THRESHOLD=4
AGENT_ALERT_QUARANTINED_REGIONS_THRESHOLD=2
AGENT_ALERT_REQUEST_TIMEOUT_MS=8000

# Optional: ERC-8004 Registry Addresses
IDENTITY_REGISTRY_ADDRESS=0x...
REPUTATION_REGISTRY_ADDRESS=0x...

# Optional: Huginn reasoning provenance contract
# Source of truth (Sepolia): contracts/huginn-registry/deployments/sepolia.json
HUGINN_REGISTRY_ADDRESS=0x0

# Heartbeat auth (recommended in production)
HEARTBEAT_SECRET=replace-with-random-secret

# Rate limiting
# memory: local in-memory buckets (default)
# upstash: distributed buckets via Upstash Redis REST API
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_GLOBAL_PER_MIN=120
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# State persistence backend for loop runtime/actions/snapshots
# auto: use Upstash when configured, else local file
# upstash: require Upstash keys
# file: force local file (not multi-replica safe)
AGENT_STATE_BACKEND=auto
AGENT_STATE_UPSTASH_KEY=starknet-agentic:prediction-agent:state:v1
# Optional local state file override (used when backend=file or Upstash unavailable)
AGENT_STATE_FILE=
OPENCLAW_ALLOW_PRIVATE_PEERS=false
OPENCLAW_FORECAST_TTL_HOURS=72
# Network BYO agent liveness windows
NETWORK_AGENT_ONLINE_TTL_SECS=180
NETWORK_AGENT_STALE_TTL_SECS=900
# Optional: external heartbeat worker (independent hosted agent node)
NETWORK_HEARTBEAT_BASE_URL=http://localhost:3001
NETWORK_HEARTBEAT_RPC_URL=https://starknet-sepolia.public.blastapi.io
NETWORK_HEARTBEAT_WALLET_ADDRESS=
NETWORK_HEARTBEAT_PRIVATE_KEY=
NETWORK_HEARTBEAT_AGENT_ID=
NETWORK_HEARTBEAT_INTERVAL_MS=60000
NETWORK_HEARTBEAT_JITTER_MS=5000
NETWORK_HEARTBEAT_CHALLENGE_TTL_SECS=180
NETWORK_HEARTBEAT_TIMEOUT_MS=10000
NETWORK_HEARTBEAT_ENDPOINT_URL=
NETWORK_HEARTBEAT_RUNTIME_PROVIDER=independent-node
NETWORK_HEARTBEAT_RUNTIME_REGION=
NETWORK_HEARTBEAT_RUNTIME_SCHEDULER=self
NETWORK_HEARTBEAT_RUNTIME_VERSION=
NETWORK_HEARTBEAT_RUNTIME_NODE_ID=
NETWORK_HEARTBEAT_RUNTIME_METADATA_JSON=

# Optional: full external worker node (research + forecast + debate + optional bets)
NETWORK_AGENT_BASE_URL=http://localhost:3001
NETWORK_AGENT_RPC_URL=https://starknet-sepolia.public.blastapi.io
NETWORK_AGENT_WALLET_ADDRESS=
NETWORK_AGENT_PRIVATE_KEY=
NETWORK_AGENT_ID=
NETWORK_AGENT_NAME=Independent Forecaster
NETWORK_AGENT_HANDLE=independent-forecaster
NETWORK_AGENT_DESCRIPTION=
NETWORK_AGENT_MODEL_LABEL=external-agent
NETWORK_AGENT_TOPICS=politics,tech,sports,world
NETWORK_AGENT_ENDPOINT_URL=
NETWORK_AGENT_CARD_URL=
NETWORK_AGENT_PROOF_URL=
NETWORK_AGENT_METADATA_JSON=
NETWORK_AGENT_INTERVAL_MS=90000
NETWORK_AGENT_JITTER_MS=5000
NETWORK_AGENT_MAX_FORECASTS_PER_TICK=2
NETWORK_AGENT_MAX_DEBATES_PER_TICK=1
NETWORK_AGENT_MARKET_LIMIT=40
NETWORK_AGENT_FORECAST_COOLDOWN_MS=900000
NETWORK_AGENT_DEBATE_COOLDOWN_MS=600000
NETWORK_AGENT_RESEARCH_SOURCES=polymarket,news,web,rss,onchain,social
NETWORK_AGENT_RESEARCH_TIMEOUT_MS=20000
NETWORK_AGENT_REQUEST_TIMEOUT_MS=12000
NETWORK_AGENT_CHALLENGE_TTL_SECS=180
NETWORK_AGENT_FORECAST_MODEL=
NETWORK_AGENT_DEBATE_MODEL=
NETWORK_AGENT_LLM_ENABLED=true
NETWORK_AGENT_ENABLE_XAI_TOOLS=false
NETWORK_AGENT_MAX_PAID_CALLS_PER_HOUR=12
NETWORK_AGENT_MAX_PAID_CALLS_PER_DAY=120
NETWORK_AGENT_PREMIUM_LOCKOUT_SECS=3600
NETWORK_AGENT_SYNC_PROFILE_EVERY_TICKS=20
NETWORK_AGENT_EXECUTE_BETS=false
NETWORK_AGENT_BET_AMOUNT_STRK=1
NETWORK_AGENT_BET_MIN_EDGE=0.15
NETWORK_AGENT_BET_MIN_CONFIDENCE=0.55
NETWORK_AGENT_MIN_RESERVE_STRK=0.5
NETWORK_AGENT_TX_WAIT_TIMEOUT_MS=12000
NETWORK_AGENT_RUNTIME_PROVIDER=independent-node
NETWORK_AGENT_RUNTIME_REGION=
NETWORK_AGENT_RUNTIME_SCHEDULER=self
NETWORK_AGENT_RUNTIME_VERSION=
NETWORK_AGENT_RUNTIME_NODE_ID=
NETWORK_AGENT_RUNTIME_METADATA_JSON=

# Optional: child agent server runtime (BitsagE Cloud)
BITSAGE_CLOUD_API_URL=
BITSAGE_CLOUD_API_TOKEN=
BITSAGE_CLOUD_ESCROW_ADDRESS=
CHILD_AGENT_SERVER_PROVIDER=bitsage-cloud
CHILD_AGENT_SERVER_ENABLED=false
CHILD_AGENT_SERVER_TIER=nano
CHILD_AGENT_SERVER_REGIONS=iad,sfo,fra
CHILD_AGENT_SERVER_ESCROW_DEPOSIT_STRK=0
CHILD_AGENT_SERVER_HEARTBEAT_EVERY=3
CHILD_AGENT_SERVER_FAILOVER_AFTER_FAILURES=2
CHILD_AGENT_SERVER_MAX_FAILOVERS=5
CHILD_AGENT_SERVER_FAILOVER_COOLDOWN_SECS=180
CHILD_AGENT_SERVER_REGION_QUARANTINE_SECS=600

# Child self-scheduler (runtime machines tick themselves)
CHILD_AGENT_SELF_SCHEDULER_ENABLED=false
CHILD_AGENT_SELF_SCHEDULER_INTERVAL_MS=60000
CHILD_AGENT_SELF_SCHEDULER_JITTER_MS=5000

# Agent key custody
# memory: process memory only (default)
# local-encrypted: AES-256-GCM with AGENT_KEY_CUSTODY_MASTER_KEY
# aws-kms: encrypt/decrypt with AWS KMS key id
AGENT_KEY_CUSTODY_PROVIDER=memory
AGENT_KEY_CUSTODY_MASTER_KEY=
AGENT_KEY_CUSTODY_AWS_KMS_KEY_ID=
AGENT_KEY_CUSTODY_AWS_REGION=

# Proof pipeline (receipt verify + optional Arweave anchor via audit relay)
PROOF_PIPELINE_AUTO_ENABLED=true
PROOF_PIPELINE_MAX_RECORDS=500
PROOF_AUDIT_RELAY_URL=
PROOF_AUDIT_RELAY_API_KEY=
PROOF_ARWEAVE_GATEWAY=https://arweave.net
