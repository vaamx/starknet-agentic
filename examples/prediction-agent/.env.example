# Starknet RPC
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io
STARKNET_CHAIN_ID=SN_SEPOLIA
# DATABASE_URL for Postgres production deployment (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hivecaster
# direct | starkzap | avnu
# starkzap mode requires `starkzap` installed in examples/prediction-agent
EXECUTION_SURFACE=direct
# standard: all operations may run over starkzap
# hardened: only placeBet/recordPrediction/claimWinnings may run over starkzap
EXECUTION_PROFILE=hardened
# Optional: if true and Starkzap SDK is unavailable, fallback to direct execution
STARKZAP_FALLBACK_TO_DIRECT=false

# Agent Account (for autonomous betting)
AGENT_PRIVATE_KEY=0x...
AGENT_ADDRESS=0x...

# Deployed Contract Addresses (Sepolia)
MARKET_FACTORY_ADDRESS=0x...
ACCURACY_TRACKER_ADDRESS=0x...
COLLATERAL_TOKEN_ADDRESS=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d

# Anthropic API (for agent forecasting)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: ERC-8004 Registry Addresses
IDENTITY_REGISTRY_ADDRESS=0x...
REPUTATION_REGISTRY_ADDRESS=0x...

# Web2 auth/session secret (required for production)
AUTH_SECRET=change-me-with-at-least-32-characters

# Optional default market oracle for market creation API
MARKET_ORACLE_ADDRESS=0x...

# Autonomous Loop Hardening
AGENT_LOOP_EXECUTE_BETS=false
AGENT_LOOP_MIN_CONFIDENCE=0.15
