{
  "name": "prediction-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "verify:runtime": "node ./scripts/require-node22.cjs",
    "clean:next-types": "node ./scripts/clean-next-types.cjs",
    "typegen": "node ./scripts/require-node22.cjs && node ./scripts/clean-next-types.cjs && next typegen",
    "typecheck": "node ./scripts/require-node22.cjs && node ./scripts/clean-next-types.cjs && next typegen && tsc --noEmit --incremental false",
    "dev": "node ./scripts/require-node22.cjs && next dev --webpack --port 3001",
    "build": "node ./scripts/require-node22.cjs && node ./scripts/clean-next-types.cjs && next typegen && PREDICTION_AGENT_BUILD=true NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--disable-warning=ExperimentalWarning\" next build --webpack",
    "start": "node ./scripts/require-node22.cjs && next start",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "next": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "starknet": "^6.23.1",
    "zod": "^3.23.0",
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "peerDependencies": {
    "starkzap": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "starkzap": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.20",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "prisma": "^6.14.0"
  }
}
