# Starknet RPC
STARKNET_RPC_URL=https://starknet-mainnet.g.alchemy.com/v2/YOUR_KEY
STARKNET_SEPOLIA_RPC_URL=https://starknet-sepolia.g.alchemy.com/v2/YOUR_KEY

# Agent Account
STARKNET_ACCOUNT_ADDRESS=0x...
STARKNET_PRIVATE_KEY=0x...
STARKNET_EXECUTION_SURFACE=direct
# standard: legacy behavior (all write tools may run on starkzap surface)
# hardened: only approved tools (transfer/swap) may run on starkzap surface
STARKNET_EXECUTION_PROFILE=hardened
# Optional: if true and STARKNET_EXECUTION_SURFACE=starkzap, fallback to direct execution when Starkzap is unavailable.
STARKNET_STARKZAP_FALLBACK_TO_DIRECT=false
STARKNET_SESSION_PRIVATE_KEY=0x...
STARKNET_SESSION_PUBLIC_KEY=0x...
STARKNET_SIGNER=session
STARKNET_AGENT_ACCOUNT_FACTORY=0x...

# avnu API (optional - defaults shown)
AVNU_BASE_URL=https://starknet.api.avnu.fi
AVNU_PAYMASTER_URL=https://starknet.paymaster.avnu.fi

# avnu Integrator (optional -- for integrator fees)
AVNU_API_KEY=
