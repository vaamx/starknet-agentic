    "skills/starknet-identity": {
      "release-type": "node",
      "package-name": "@starknet-agentic/skill-identity"
    },
    "skills/starknet-mini-pay": {
      "release-type": "node",
      "package-name": "@starknet-agentic/skill-mini-pay"
    },
    "skills/starknet-wallet": {
      "release-type": "node",
      "package-name": "@starknet-agentic/skill-wallet"
    }
  }
