    "packages/starknet-a2a": {
      "release-type": "node",
      "package-name": "@starknet-agentic/a2a"
    },
    "packages/starknet-agent-passport": {
      "release-type": "node",
      "package-name": "@starknet-agentic/agent-passport"
    },
    "packages/starknet-mcp-server": {
      "release-type": "node",
