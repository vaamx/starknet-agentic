# HuginnRegistry Sepolia deployment configuration
# Copy to .env and source it before running scripts.

# Required for deployment
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io
DEPLOYER_ADDRESS=0xYOUR_DEPLOYER_ACCOUNT
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
HUGINN_VERIFIER_ADDRESS=0xYOUR_VERIFIER_CONTRACT

# Optional
DEPLOYER_ACCOUNT_NAME=huginn_sepolia_deployer
STARKNET_ACCOUNTS_FILE=$HOME/.starknet_accounts/starknet_open_zeppelin_accounts.json
STARKNET_EXPLORER_BASE_URL=https://sepolia.voyager.online

# For verification script
HUGINN_REGISTRY_ADDRESS=0xYOUR_DEPLOYED_HUGINN_REGISTRY
